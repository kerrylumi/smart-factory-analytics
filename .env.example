# Kopeeri .env failiks ja muuda väärtused enda omaks.
# .env on .gitignore-s — paroolid ei lähe repo'sse.

# --- Analüütika andmebaas (pgDuckDB) ---
POSTGRES_USER=praktikum
POSTGRES_PASSWORD=praktikum
POSTGRES_DB=praktikum

# --- Airflow metaandmebaas ---
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_DB=airflow

# Airflow konteineri kasutaja UID (Linuxis: id -u, Windowsis/Macis jäta 50000)
AIRFLOW_UID=50000

# Airflow JWT — genereeri reaalseks deploy'ks pikk juhuslik string
AIRFLOW__API_AUTH__JWT_SECRET=change_me_in_real_deploy
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Airflow UI admin
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# --- Superset metaandmebaas ---
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=muuda_mind
SUPERSET_DB_NAME=superset_meta

# --- Superset rakendus ---
# SECRET_KEY: genereeri käsuga: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=genereeri_pikk_juhuslik_string_siin_min_32_tahemarki
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_PORT_HOST=8088
